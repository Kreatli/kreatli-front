            "type": "string",
            "enum": [
              "review-needed",
              "in-progress",
              "changes-required",
              "approved"
            ],
            "nullable": true
          },
          "assigneeId": { "type": "string", "nullable": true }
        },
        "required": ["status"]
      },
      "FolderBodyDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "parentId": { "type": "string" }
        },
        "required": ["name"]
      },
      "FolderEditBodyDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "parentId": { "type": "string", "nullable": true }
        }
      },
      "AssetRemoveBodyDto": {
        "type": "object",
        "properties": {
          "assetIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["assetIds"]
      },
      "ChatBodyDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "members": { "type": "string" }
        },
        "required": ["members"]
      },
      "ProjectAssetDto": { "type": "object", "properties": {} },
      "ChatMessageDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "sender": { "$ref": "#/components/schemas/UserDto" },
