            "type": "array",
            "items": { "$ref": "#/components/schemas/ProjectAssetDto" }
          },
          "content": { "type": "string" },
          "createdAt": { "type": "string" },
          "readBy": { "type": "array", "items": { "type": "string" } },
          "isPinned": { "type": "boolean" }
        },
        "required": [
          "id",
          "sender",
          "assets",
          "content",
          "createdAt",
          "readBy",
          "isPinned"
        ]
      },
      "ChatDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "members": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserDto" }
          },
          "cover": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/InterfaceImageDto" }]
          },
          "createdAt": { "type": "string" },
          "createdBy": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/UserDto" }]
          },
          "updatedAt": { "type": "string", "nullable": true },
          "updatedBy": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/UserDto" }]
          },
          "lastMessage": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/ChatMessageDto" }]
          },
          "pinnedMessages": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ChatMessageDto" }
          }
        },
        "required": [
          "id",
          "name",
          "members",
          "cover",
          "createdAt",
          "createdBy",
          "updatedAt",
          "updatedBy",
          "lastMessage",
          "pinnedMessages"
        ]
      },
      "ProjectLogsDto": {
        "type": "object",
        "properties": {
