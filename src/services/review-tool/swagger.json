  "info": {
    "title": "Kreatli review tool",
    "description": "The Kreatli review tool API description",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "InterfaceImageDto": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "originalFileName": { "type": "string" },
          "fileSize": { "type": "number" },
          "width": { "type": "number" },
          "height": { "type": "number" },
          "createdAt": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": [
          "url",
          "originalFileName",
          "fileSize",
          "width",
          "height",
          "createdAt",
          "description"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "name": { "type": "string" },
          "avatar": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/InterfaceImageDto" }]
          }
        },
        "required": ["id", "email", "name", "avatar"]
      },
      "SignUpBodyDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" },
          "name": { "type": "string" },
          "isEmailVerified": { "type": "boolean" }
        },
        "required": ["email", "password", "name"]
      },
      "SignUpResultDto": {
        "type": "object",
        "properties": {
          "link": { "type": "string" },
          "user": { "$ref": "#/components/schemas/UserDto" }
        },
        "required": ["link", "user"]
      },
      "SignUpWithTokenBodyDto": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "password": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["token", "password", "name"]
      },
      "SignInResultDto": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "user": { "$ref": "#/components/schemas/UserDto" }
        },
        "required": ["token", "user"]
      },
      "SignInBodyDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      },
      "TokenBodyDto": {
        "type": "object",
        "properties": { "token": { "type": "string" } },
        "required": ["token"]
      },
      "ProjectBodyDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "members": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name", "description", "members"]
      },
      "ProjectFileDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "createdAt": { "type": "string" },
          "createdBy": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/UserDto" }]
          },
          "status": {
            "type": "string",
            "enum": [
              "review-needed",
              "in-progress",
              "changes-required",
              "approved"
            ],
            "nullable": true
          },
          "assignee": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/UserDto" }]
          },
          "fileSize": { "type": "number" },
          "fileType": { "type": "string" },
          "format": { "type": "string" },
          "url": { "type": "string" },
          "metadata": { "type": "object" },
          "type": { "type": "string", "enum": ["file"] }
        },
        "required": [
          "id",
          "name",
          "description",
          "createdAt",
          "createdBy",
          "status",
          "assignee",
          "fileSize",
          "fileType",
          "format",
          "url",
          "metadata",
          "type"
        ]
      },
      "ProjectFolderChild": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["folder", "file"] },
          "url": { "type": "string" }
        },
        "required": ["id", "name", "description", "type"]
      },
      "ProjectFolderDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "createdAt": { "type": "string" },
          "createdBy": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/UserDto" }]
          },
          "children": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProjectFolderChild" }
          },
          "fileCount": { "type": "number" },
          "totalFileSize": { "type": "number" },
          "type": { "type": "string", "enum": ["folder"] }
        },
        "required": [
          "id",
          "name",
          "description",
          "createdAt",
          "createdBy",
          "children",
          "fileCount",
          "totalFileSize",
          "type"
        ]
      },
      "ProjectMemberDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "user": { "$ref": "#/components/schemas/UserDto" },
          "status": {
            "type": "string",
            "enum": ["invited", "joined", "removed", "left"]
          },
          "email": { "type": "string" },
          "invitedAt": { "type": "string" },
          "role": { "type": "string", "enum": ["owner", "contributor"] }
        },
        "required": ["id", "user", "status", "email", "invitedAt", "role"]
      },
      "ProjectDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "cover": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/InterfaceImageDto" }]
          },
          "createdAt": { "type": "string" },
          "createdBy": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/UserDto" }]
          },
          "updatedAt": { "type": "string", "nullable": true },
          "updatedBy": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/UserDto" }]
          },
          "members": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProjectMemberDto" }
          },
          "status": {
            "type": "string",
            "enum": ["active", "completed", "archived"]
          },
          "fileCount": { "type": "number" },
          "totalFileSize": { "type": "number" },
          "assets": {
            "type": "array",
            "items": {
              "oneOf": [
                { "$ref": "#/components/schemas/ProjectFolderDto" },
                { "$ref": "#/components/schemas/ProjectFileDto" }
              ]
            },
            "description": "An array of assets which can be folders or files."
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "cover",
          "createdAt",
          "createdBy",
          "updatedAt",
          "updatedBy",
          "members",
          "status",
          "fileCount",
          "totalFileSize",
          "assets"
        ]
      },
      "ProjectEditBodyDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "assets": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name", "description", "assets"]
      },
      "ProjectStatusBodyDto": {
        "type": "object",
        "properties": { "status": { "type": "string" } },
        "required": ["status"]
      },
      "ProjectMemberBodyDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["owner", "contributor"],
            "default": "contributor"
          }
        },
        "required": ["email", "role"]
      },
      "FileEditBodyDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "parentId": { "type": "string", "nullable": true },
